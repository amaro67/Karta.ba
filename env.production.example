# Environment variables for Karta.ba Production
# Copy this file to .env and update the values

# Database Configuration
SQLSERVER_SA_PASSWORD=your_secure_sqlserver_password_here

# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_at_least_32_characters_long_for_production

# Email Configuration
EMAIL_FROM_EMAIL=your_email@domain.com
EMAIL_SMTP_HOST=smtp.your-provider.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=your_email@domain.com
EMAIL_SMTP_PASSWORD=your_email_password

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Security Configuration
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
