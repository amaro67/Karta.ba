# Karta.ba Environment Variables
# Copy this file to .env and fill in your actual values for production

# Database Configuration
CONNECTION_STRING=Data Source=KartaDb.db

# Stripe Configuration (Production Keys)
STRIPE_SECRET_KEY=sk_live_your_production_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_production_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_production_webhook_secret_here

# Email Configuration
EMAIL_FROM_EMAIL=amar.omerovic0607@gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=amar.omerovic0607@gmail.com
EMAIL_SMTP_PASSWORD="glat uuwp rmos lobo"
EMAIL_USE_RABBITMQ=false

# RabbitMQ Configuration
RABBITMQ_HOSTNAME=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# JWT Configuration
JWT_SECRET_KEY=Yq9t7Gz2dKxB5vR1hM8nJ4sT0pZ3cL6wF2rQ8eN9yU5aH7jV3mC4oP1bX0tR5gD2
JWT_EXPIRY_MINUTES=60
